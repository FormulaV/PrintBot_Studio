<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="#CFE3D8" />
            <stroke android:width="2dp" android:color="#215B63" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="8dp" />
            <gradient
                android:angle="0"
                android:startColor="#FFFFFF"
                android:endColor="#DDEBEA" />
            <stroke android:width="1dp" android:color="#7DA89A" />
        </shape>
    </item>
</selector>
