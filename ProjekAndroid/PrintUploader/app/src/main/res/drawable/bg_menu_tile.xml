<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="#DCE8D0" />
            <stroke android:width="2dp" android:color="#215B63" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="8dp" />
            <gradient
                android:angle="90"
                android:startColor="#FFFFFF"
                android:endColor="#F2E4C7" />
            <stroke android:width="1dp" android:color="#CDAA7D" />
        </shape>
    </item>
</selector>
