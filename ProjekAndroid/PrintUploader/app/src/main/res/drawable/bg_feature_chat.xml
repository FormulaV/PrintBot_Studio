<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="#E8D6B6" />
            <stroke android:width="2dp" android:color="#B89063" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="8dp" />
            <gradient
                android:angle="0"
                android:startColor="#FFFDF6"
                android:endColor="#F4E3C4" />
            <stroke android:width="1dp" android:color="#CDAA7D" />
        </shape>
    </item>
</selector>
